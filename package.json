{
  "name": "brand-asset-generator",
  "version": "2.0.0",
  "description": "Universal brand asset generator for logos and icons via Node.js Canvas API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "npx ts-node src/cli/cli.ts",
    "batch": "npx ts-node src/cli/cli.ts --batch",
    "build": "npx tsc",
    "start:js": "node dist/cli/cli.js",
    "batch:js": "node dist/cli/cli.js --batch",
    "list-styles": "npx ts-node src/cli/cli.ts --list-styles",
    "generate-logo": "npx ts-node src/cli/cli.ts --generate-logo",
    "generate-icon": "npx ts-node src/cli/cli.ts --generate-icon",
    "generate-batch": "npx ts-node src/cli/cli.ts --batch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "logo-generator",
    "icon-generator",
    "brand-assets",
    "canvas",
    "typescript",
    "automation",
    "design-automation"
  ],
  "license": "MIT",
  "dependencies": {
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  }
}
