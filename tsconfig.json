{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist",
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "src/core/**/*.ts",
    "src/utils/**/*.ts",
    "src/cli/**/*.ts",
    "src/styles/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "tests", "examples"]
}
